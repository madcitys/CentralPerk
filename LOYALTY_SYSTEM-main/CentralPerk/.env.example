NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_ENABLE_DEMO_AUTH=true
NEXT_PUBLIC_FORCE_CUSTOMER_DEMO_AUTH=false

# Server-only secret. Do not expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:5432/postgres

POINTS_ENGINE_URL=http://localhost:4001
NEXT_PUBLIC_POINTS_ENGINE_URL=http://localhost:4001
CAMPAIGN_SERVICE_URL=http://localhost:4002
NEXT_PUBLIC_CAMPAIGN_SERVICE_URL=http://localhost:4002
GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000


